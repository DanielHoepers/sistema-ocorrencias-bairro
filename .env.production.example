# Use este arquivo como referencia para preencher as variaveis no painel da hospedagem.
# Nao coloque senhas reais no GitHub.

# Backend
PORT=10000
SERVER_FORWARD_HEADERS_STRATEGY=native
SPRING_APPLICATION_NAME=ocorrencias
SPRING_DATASOURCE_URL=jdbc:postgresql://SEU_HOST_SUPABASE:6543/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres.SEU_PROJECT_REF
SPRING_DATASOURCE_PASSWORD=TROQUE_PELA_SENHA_DO_BANCO
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_OPEN_IN_VIEW=false
SPRING_JPA_FORMAT_SQL=false
SPRING_FLYWAY_ENABLED=true

# Frontend permitido a chamar o backend
APP_CORS_ALLOWED_ORIGINS=https://SEU_FRONTEND.onrender.com
APP_CORS_ALLOWED_ORIGIN_PATTERNS=

# Sessao e seguranca
APP_JWT_SECRET=GERE_UMA_CHAVE_FORTE_COM_PELO_MENOS_64_CARACTERES
APP_JWT_EXPIRATION_SECONDS=7200
APP_AUTH_COOKIE_NAME=bairro_token
APP_AUTH_COOKIE_SECURE=true
APP_AUTH_COOKIE_SAME_SITE=None

# Administrador inicial.
# Use true no primeiro deploy para criar seu usuario administrador.
# Depois que entrar no sistema, troque para false.
APP_ADMIN_CREATE_ENABLED=true
APP_ADMIN_NAME=Daniel Hoepers
APP_ADMIN_EMAIL=danielrch.hoepers@gmail.com
APP_ADMIN_PASSWORD=CRIE_UMA_SENHA_FORTE_SOMENTE_NO_PAINEL_DA_HOSPEDAGEM

# Frontend
VITE_API_URL=https://SEU_BACKEND.onrender.com/api
