# Geral
COMPOSE_PROJECT_NAME=sistema-ocorrencias-bairro
TZ=America/Sao_Paulo

# Banco de dados PostgreSQL
POSTGRES_IMAGE=postgres:15-alpine
POSTGRES_CONTAINER_NAME=ocorrencias-db
POSTGRES_DB=ocorrencias_db
POSTGRES_USER=ocorrencias_user
POSTGRES_PASSWORD=troque_esta_senha
POSTGRES_HOST_PORT=5432
POSTGRES_CONTAINER_PORT=5432
POSTGRES_INTERNAL_HOST=db
POSTGRES_DATA_PATH=/var/lib/postgresql/data
POSTGRES_HEALTHCHECK_INTERVAL=10s
POSTGRES_HEALTHCHECK_TIMEOUT=5s
POSTGRES_HEALTHCHECK_RETRIES=5

# Backend Spring Boot
BACKEND_CONTAINER_NAME=ocorrencias-backend
BACKEND_BUILD_CONTEXT=./backend
BACKEND_HOST_PORT=8080
BACKEND_CONTAINER_PORT=8080
SERVER_PORT=8080
SPRING_APPLICATION_NAME=ocorrencias
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_OPEN_IN_VIEW=false
SPRING_JPA_FORMAT_SQL=true
SPRING_FLYWAY_ENABLED=true

# Autenticacao, cookie e seguranca
APP_JWT_SECRET=troque_esta_chave_por_uma_chave_grande_e_secreta
APP_JWT_EXPIRATION_SECONDS=7200
APP_AUTH_COOKIE_NAME=bairro_token
APP_AUTH_COOKIE_SECURE=false
APP_AUTH_COOKIE_SAME_SITE=Lax
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:3000,http://127.0.0.1:3000,http://localhost
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://192.168.*.*:*,http://10.*.*.*:*,http://172.*.*.*:*

# Usuario administrador criado em desenvolvimento
APP_ADMIN_CREATE_ENABLED=true
APP_ADMIN_NAME=Administrador
APP_ADMIN_EMAIL=admin@bairro.local
APP_ADMIN_PASSWORD=troque_esta_senha_admin

# Frontend
FRONTEND_CONTAINER_NAME=ocorrencias-frontend
FRONTEND_BUILD_CONTEXT=./frontend
FRONTEND_HOST_PORT=3000
FRONTEND_CONTAINER_PORT=80
VITE_API_URL=http://localhost:8080/api
